<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app_shell"
    android:orientation="vertical">

    <FrameLayout
        android:id="@+id/content_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingBottom="@dimen/content_bottom_spacing" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:layout_marginStart="@dimen/bottom_nav_margin"
        android:layout_marginEnd="@dimen/bottom_nav_margin"
        android:layout_marginBottom="@dimen/bottom_nav_margin"
        android:background="@drawable/bg_bottom_bar"
        android:elevation="14dp"
        android:paddingTop="@dimen/bottom_nav_padding_top"
        android:paddingBottom="@dimen/bottom_nav_padding_bottom"
        app:itemIconTint="@color/bottom_nav_tint"
        app:itemTextColor="@color/bottom_nav_tint"
        app:itemRippleColor="@android:color/transparent"
        app:itemActiveIndicatorStyle="@style/JumperBottomNavigationActiveIndicator"
        app:itemPaddingTop="8dp"
        app:itemPaddingBottom="6dp"
        app:labelVisibilityMode="labeled"
        app:menu="@menu/main_bottom_nav" />
</LinearLayout>